{
  "name": "cf-flag",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "go run github.com/syumai/workers/cmd/workers-assets-gen -mode=go && GOOS=js GOARCH=wasm go build -o ./build/app.wasm .",
    "deploy": "wrangler deploy",
    "dev": "wrangler dev",
    "start": "wrangler dev",
    "db:init": "wrangler d1 execute cf-flag --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute cf-flag --remote --file=./schema.sql"
  },
  "devDependencies": {
    "wrangler": "^4.84.1"
  }
}
